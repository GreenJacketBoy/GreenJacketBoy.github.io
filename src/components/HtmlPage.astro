---
interface Props {
  title: string;
}

const {title = "Home"} = Astro.props;
---

<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/assets/images/favicon.png" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{ title }</title>
</head>

<html lang="en">
  <body>
    <slot />
  </body>
</html>

<!-- STYLE -->

<style>
  html {
    overscroll-behavior-y: none;
  }

  body {
    margin: 0;
    min-height: 100vh;
  }
</style>