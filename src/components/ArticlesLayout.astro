---
import Footer from "../components/Footer.astro"
import HtmlPage from "../components/HtmlPage.astro"
---
<HtmlPage title="Articles">

  <main>

    <!-- used this font for the image : https://www.fontspace.com/anderlecht-font-f126580 -->
    <a href="/Articles" class="articles-image"><img id="articles-image" src="/assets/images/articles.webp" width="397" height="81" alt="Articles Page"></a>
  
    <hr>
    <article>
      <slot />
    </article>

  </main>
  <space-between></space-between>
  <Footer style="articles"/>
</HtmlPage>

<style is:global>

  :root {
      --articles-border-color: #154fa1;
      --figcaption-color: #a8a8a8;
  }

  body {
    background: radial-gradient(circle, #000 20%, #154fa1 32%, #000 46%, #000 75%, #154fa1 85%, #000 95%);
    color: rgb(250, 250, 250);

    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
  }

  space-between-main-and-footer {
    flex: 1;
  }

  main {
    font-size: large;
    max-width: 1075px;

    margin-left: auto;
    margin-right: auto;
    padding: 20px;

    border-left: 3px groove var(--articles-border-color);
    border-right: 3px groove var(--articles-border-color);
    border-bottom: 3px groove var(--articles-border-color);

    backdrop-filter: blur(35px);
    background-color: rgb(0, 0, 0, 0.6);
  }

  hr {
    margin-left: 2%;
    margin-right: 2%;
    color: var(--articles-border-color);
  }

  .articles-image {
    cursor: pointer;
  }

  a {
    color: #0e5dcc;
    transition: color 0.005s;
  }

  a:visited {
    color: var(--articles-border-color);
  }

  a:hover {
    color: #2a77e2;
  }

  h2 {
    color: #0e5dcc;
  }

  .article {
    margin-left: 25px;
  }

  .article p {
    margin-top: 0;
    color: #ffffffd2;
  }

  .article h3 {
    margin-bottom: 0;
  }

  #articles-image {
    transition: all 250ms ease-in-out;
    padding-inline: .5em;
    border-radius: 13px;
  }

  #articles-image:hover {
    filter: brightness(1.5);
  }

  figure img {
    width: 100%;
    height: auto;
  }

  figcaption {
    color: var(--figcaption-color);
  }

  /* RESPONSIVE HERE */

  /* why 443 pixels ?
      - 397 : width of the image
      - 20 * 2 : padding
      - 3 * 2 : width of the border
  */
  @media screen and (max-width: 443px) {
    #articles-image {
      width: 100%;
      height:auto;
    }
  }
</style>